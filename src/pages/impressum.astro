---
import Base from '~/layouts/Base.astro';

// Curly placeholders are written as plain strings so Astro does not try to
// evaluate them as JSX expressions.
const ADRESSE = '{{ADRESSE}}';
const EMAIL   = '{{EMAIL}}';

const description =
  'Impressum nach § 5 DDG für die private akademische Website von Rouven Jahnke.';
---

<Base title="Impressum" description={description}>
  <article class="prose" lang="de">
    <header class="page-header">
      <p class="page-header__eyebrow">Rechtliches</p>
      <h1>Impressum</h1>
      <p class="page-header__lede">
        Angaben gemäß § 5 Digitale-Dienste-Gesetz (DDG).
      </p>
    </header>

    <h2>Diensteanbieter</h2>
    <address>
      Rouven Jahnke<br />
      {ADRESSE}
    </address>

    <h2>Kontakt</h2>
    <dl>
      <dt>E-Mail</dt>
      <dd>{EMAIL}</dd>
    </dl>

    <h2>Verantwortlich für den Inhalt</h2>
    <p>Rouven Jahnke (Anschrift wie oben).</p>

    <h2>Hinweise</h2>
    <p>
      Diese Website ist eine private, nicht-gewerbliche akademische
      Homepage. Sie dient ausschließlich der Darstellung wissenschaftlicher
      Interessen und persönlicher Tätigkeiten und verfolgt keine
      wirtschaftlichen Zwecke. Eine Eintragung in einem Handelsregister
      besteht nicht; eine Umsatzsteuer-Identifikationsnummer wird nicht
      geführt.
    </p>
    <p>
      Für eigene Inhalte ist der Betreiber gemäß § 7 Abs. 1 DDG nach den
      allgemeinen Gesetzen verantwortlich. Eine Verpflichtung zur
      Überwachung übermittelter oder gespeicherter fremder Informationen
      besteht nach §§ 8 bis 10 DDG nicht. Auf die Inhalte verlinkter
      externer Seiten besteht kein Einfluss; bei Bekanntwerden von
      Rechtsverstößen werden entsprechende Links unverzüglich entfernt.
    </p>
  </article>
</Base>
