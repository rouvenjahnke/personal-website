---
import Base from '~/layouts/Base.astro';

// Curly placeholders are written as plain strings so Astro does not try to
// evaluate them as JSX expressions. Replace before publishing.
const FULL_NAME    = 'Rouven Jahnke';
const STREET       = '{{STREET_AND_NUMBER}}';
const POSTAL_CITY  = '{{POSTCODE_CITY}}';
const COUNTRY      = 'Germany';
const EMAIL        = '{{EMAIL}}';
const PHONE        = '{{PHONE_OR_EMPTY}}';   // optional; remove the dt/dd if empty

const description =
  'Legal notice (Impressum) under § 5 of the German Digital Services Act (DDG) for Rouven Jahnke\u2019s personal academic website.';
---

<Base title="Legal Notice" description={description}>
  <article class="prose" lang="en">
    <header class="page-header">
      <p class="page-header__eyebrow">Legal</p>
      <h1>Legal Notice <span lang="de" style="font-style: italic; color: var(--color-text-muted); font-size: 0.6em;">(Impressum)</span></h1>
      <p class="page-header__lede">
        Information pursuant to § 5 of the German Digital Services Act
        (<abbr lang="de" title="Digitale-Dienste-Gesetz">DDG</abbr>),
        which superseded the
        <abbr title="Telemediengesetz">TMG</abbr> in May 2024.
      </p>
    </header>

    <h2>Service provider</h2>
    <address>
      {FULL_NAME}<br />
      {STREET}<br />
      {POSTAL_CITY}<br />
      {COUNTRY}
    </address>

    <h2>Contact</h2>
    <dl>
      <dt>Email</dt>
      <dd><a href={`mailto:${EMAIL}`}>{EMAIL}</a></dd>
      <dt>Phone</dt>
      <dd>{PHONE}</dd>
    </dl>

    <h2>Responsible for content</h2>
    <p>
      {FULL_NAME} (address as above), in accordance with § 18 paragraph 2 of the
      Interstate Media Treaty (<abbr lang="de" title="Medienstaatsvertrag">MStV</abbr>).
    </p>

    <h2>Notes on the nature of this site</h2>
    <p>
      This is a private, non-commercial academic homepage. Its sole purpose
      is to present scientific interests and personal activities; no
      commercial purpose is pursued. There is no entry in any commercial
      register, and no <abbr title="Value Added Tax">VAT</abbr>
      identification number is held.
    </p>
    <p>
      For its own content, the operator is responsible under the general
      laws pursuant to § 7 paragraph 1 DDG. Pursuant to §§ 8 to 10 DDG,
      the operator is not obliged to monitor transmitted or stored
      third-party information. The operator has no influence over the
      content of linked external sites; if any legal violations become
      known, the corresponding links will be removed without delay.
    </p>

    <h2>Online dispute resolution</h2>
    <p>
      The European Commission provides a platform for online dispute
      resolution (ODR) at
      <a href="https://ec.europa.eu/consumers/odr" rel="external noopener">
        ec.europa.eu/consumers/odr</a>.
      The operator is neither obliged nor willing to participate in
      dispute resolution proceedings before a consumer arbitration board.
    </p>

    <h2>Copyright</h2>
    <p>
      Unless otherwise indicated, all content on this site (text,
      mathematical writing, figures) is © {FULL_NAME} and licensed under
      the <a href="https://creativecommons.org/licenses/by/4.0/" rel="external noopener">Creative
      Commons Attribution&nbsp;4.0</a> licence. Code samples are released
      under the MIT licence unless stated otherwise.
    </p>

    <hr />
    <p>
      <small>
        German speakers: a German version of this notice can be requested
        by email; the legal references above (<abbr lang="de" title="Digitale-Dienste-Gesetz">DDG</abbr>,
        <abbr lang="de" title="Medienstaatsvertrag">MStV</abbr>) refer to
        German law and remain authoritative.
      </small>
    </p>
  </article>
</Base>
