---
import Base from '~/layouts/Base.astro';
import ObfuscatedEmail from '~/components/ObfuscatedEmail.astro';
import { OWNER, HAS } from '~/consts';

const description = `How to reach ${OWNER.fullName}.`;

// At least one of the rows must be present for the page to be useful;
// in the empty-everywhere starter state, the dl below collapses to just
// the email row (always rendered, even when empty, so the page is never
// dead) and the closing note.
---

<Base title="Contact" description={description}>
  <article class="prose">
    <header class="page-header">
      <p class="page-header__eyebrow">Contact</p>
      <h1>Get in touch</h1>
      <p class="page-header__lede">
        Email is the best way to reach me. Mathematical correspondence,
        corrections, and questions are all welcome.
      </p>
    </header>

    <dl>
      <dt>Email</dt>
      <dd>
        {HAS.email
          ? <ObfuscatedEmail address={OWNER.email} />
          : <em>Email address not yet published.</em>}
      </dd>

      {HAS.orcid && (
        <>
          <dt>ORCID</dt>
          <dd>
            <a href={OWNER.orcidUrl} rel="noopener noreferrer me">
              {OWNER.orcid}
            </a>
          </dd>
        </>
      )}

      {HAS.github && (
        <>
          <dt>GitHub</dt>
          <dd>
            <a href={OWNER.githubUrl} rel="noopener noreferrer me">
              @{OWNER.github}
            </a>
          </dd>
        </>
      )}

      {HAS.mathstodon && (
        <>
          <dt>Mastodon</dt>
          <dd>
            <a href={OWNER.mathstodonUrl} rel="noopener noreferrer me">
              {OWNER.mathstodon}
            </a>
          </dd>
        </>
      )}

      {HAS.address && (
        <>
          <dt>Address</dt>
          <dd>
            <address>
              {OWNER.institutionalAddress}<br />
              <small>(from {OWNER.startsBonn}, {OWNER.futureAffiliation}.)</small>
            </address>
          </dd>
        </>
      )}
    </dl>

    <hr />

    <p>
      <small>
        I read everything but reply slowly. For mathematical corrections,
        please be specific about the page or note.
      </small>
    </p>
  </article>
</Base>
