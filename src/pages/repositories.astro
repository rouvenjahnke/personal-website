---
import Base from '~/layouts/Base.astro';
import { OWNER } from '~/consts';
import { REPOSITORY_CARDS } from '~/data/profile';

const description =
  'Selected public repositories of Rouven Jahnke.';
---

<Base title="Repositories" description={description}>
  <article class="prose prose--wide page-shell">
    <header class="page-header">
      <p class="page-header__eyebrow">Repositories</p>
      <h1>Public code archive</h1>
      <p class="page-header__lede">
        This page is the more literal code-facing counterpart to the projects
        page: repositories first, narrative second.
      </p>
    </header>

    <div class="page-grid">
      <div class="page-grid__main">
        <section class="panel">
          <p class="panel__kicker">Repositories</p>
          <h2>Selected public codebases</h2>
          <ul class="record-list" role="list">
            {REPOSITORY_CARDS.map((repository) => (
              <li class="record">
                <div class="record__badge">{repository.updated}</div>
                <div class="record__body">
                  <a class="record__title" href={repository.href} rel="noopener noreferrer">
                    {repository.name}
                  </a>
                  <p class="record__meta">
                    {repository.area} · {repository.stack}
                  </p>
                  <p class="record__summary">{repository.description}</p>
                </div>
              </li>
            ))}
          </ul>
        </section>
      </div>

      <aside class="aside-stack">
        <section class="panel panel--muted">
          <p class="panel__kicker">GitHub</p>
          <h2>@{OWNER.github}</h2>
          <p>
            The complete public profile remains available on
            <a href={OWNER.githubUrl} rel="noopener noreferrer"> GitHub</a>.
          </p>
        </section>

        <section class="panel panel--muted">
          <p class="panel__kicker">Profile</p>
          <h2>Archive logic</h2>
          <p>
            Repositories are listed here because the reference GitHub-page has
            a dedicated repository view. On this site they are filtered toward
            codebases that fit the academic and technical profile.
          </p>
        </section>
      </aside>
    </div>
  </article>
</Base>
