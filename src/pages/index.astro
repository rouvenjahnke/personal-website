---
import Base from '~/layouts/Base.astro';
import SocialIcons from '~/components/SocialIcons.astro';
import { OWNER } from '~/consts';
import { getCollection } from 'astro:content';

const description =
  'Academic website of Rouven Jahnke — mathematics student in formation, working toward research in algebraic geometry.';

const allNotes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => +b.data.date - +a.data.date,
);

const selectedNotes = allNotes.slice(0, 3);
const recentUpdates = allNotes.slice(0, 4);

const trajectory = (
  await getCollection(
    'cv',
    ({ data }) =>
      !data.draft && (data.section === 'education' || data.section === 'experience'),
  )
).sort((a, b) => {
  if (b.data.order !== a.data.order) return b.data.order - a.data.order;
  return (b.data.start ?? '').localeCompare(a.data.start ?? '');
}).slice(0, 4);

const fmtNews = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const fmtMonth = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'short',
});

const fmtDay = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const parsePartialDate = (value: string): Date | null => {
  if (/^\d{4}$/.test(value)) {
    return new Date(Date.UTC(Number(value), 0, 1));
  }
  if (/^\d{4}-\d{2}$/.test(value)) {
    const [yearText, monthText] = value.split('-');
    const year = Number(yearText);
    const month = Number(monthText);
    if (Number.isNaN(year) || Number.isNaN(month)) return null;
    return new Date(Date.UTC(year, month - 1, 1));
  }
  if (/^\d{4}-\d{2}-\d{2}$/.test(value)) {
    return new Date(`${value}T00:00:00Z`);
  }
  return null;
};

const formatMoment = (value: string): string => {
  if (value === '—') return value;
  if (/^\d{4}$/.test(value)) return value;
  const parsed = parsePartialDate(value);
  if (!parsed) return value;
  if (/^\d{4}-\d{2}$/.test(value)) return fmtMonth.format(parsed);
  return fmtDay.format(parsed);
};

const formatRange = (start: string, end?: string): string => {
  if (!end) return formatMoment(start);
  if (end === 'present') return `${formatMoment(start)} – present`;
  return `${formatMoment(start)} – ${formatMoment(end)}`;
};
---

<Base description={description}>
  <div class="container home-page">
    <article class="home">
      <header class="hero">
        <div class="hero__copy">
          <p class="hero__eyebrow">Academic Dossier</p>
          <h1 class="hero__title">Rouven Jahnke</h1>
          <p class="hero__lead">
            Mathematics student in formation, working toward a research career
            in algebraic geometry.
          </p>
          <p>
            I am currently completing secondary school in Hamburg while taking
            university-level coursework in algebra, algebraic geometry, and
            topology as a <em>Frühstudent</em> at the Universität Hamburg.
          </p>
          <p>
            From October 2026 I will begin the <abbr title="Bachelor of Science">BSc</abbr>
            Mathematics programme at the Universität Bonn. The long arc is clear:
            build rigorous foundations early, write publicly as I learn, and move
            step by step toward doctoral work in pure mathematics.
          </p>
          <div class="hero__meta">
            <span class="hero__meta-item">Hamburg / Bonn</span>
            <span class="hero__meta-item">Algebraic geometry</span>
            <span class="hero__meta-item">Expository notes</span>
            <span class="hero__meta-item">Tutoring & outreach</span>
          </div>
        </div>

        <aside class="dossier panel">
          <figure class="dossier__portrait">
            <img
              class="dossier__image"
              src="/prof_pic.svg"
              alt="Profile placeholder of Rouven Jahnke"
              width="320"
              height="320"
              loading="eager"
            />
          </figure>

          <div class="dossier__block">
            <p class="panel__kicker">Current Status</p>
            <p class="dossier__headline">
              Frühstudent in mathematics at {OWNER.currentAffiliation}
            </p>
            <p class="dossier__text">
              BSc Mathematics at {OWNER.futureAffiliation} from {OWNER.startsBonn}.
            </p>
          </div>

          <dl class="detail-grid">
            <div class="detail-grid__item">
              <dt class="detail-grid__label">Focus</dt>
              <dd class="detail-grid__value">Schemes, sheaves, cubic surfaces</dd>
            </div>
            <div class="detail-grid__item">
              <dt class="detail-grid__label">Writing mode</dt>
              <dd class="detail-grid__value">Public notes and technical drafts</dd>
            </div>
            <div class="detail-grid__item">
              <dt class="detail-grid__label">Location</dt>
              <dd class="detail-grid__value">Hamburg, Germany</dd>
            </div>
            <div class="detail-grid__item">
              <dt class="detail-grid__label">Languages</dt>
              <dd class="detail-grid__value">German, English, mathematical French</dd>
            </div>
          </dl>
        </aside>
      </header>

      <div class="home-grid">
        <div class="home-grid__main">
          <section class="panel">
            <p class="panel__kicker">Orientation</p>
            <h2>Research trajectory</h2>
            <div class="insight-grid">
              <article class="insight-card">
                <h3>Training</h3>
                <p>
                  University mathematics started early and deliberately:
                  advanced coursework alongside school, with emphasis on proof,
                  abstraction, and long-form reading.
                </p>
              </article>
              <article class="insight-card">
                <h3>Present focus</h3>
                <p>
                  The current centre of gravity is algebraic geometry,
                  especially the interface between classical projective
                  problems and modern language.
                </p>
              </article>
              <article class="insight-card">
                <h3>Long horizon</h3>
                <p>
                  The aim is a sustained research profile that can mature into
                  doctoral work: careful foundations first, then sharper
                  questions, then original mathematics.
                </p>
              </article>
            </div>
          </section>

          <section class="panel">
            <p class="panel__kicker">Writing</p>
            <h2>Selected notes</h2>
            {selectedNotes.length === 0 ? (
              <p class="empty-state">No public notes yet.</p>
            ) : (
              <ul class="record-list" role="list">
                {selectedNotes.map((note) => (
                  <li class="record">
                    <div class="record__badge">
                      <time datetime={note.data.date.toISOString()}>
                        {fmtNews.format(note.data.date)}
                      </time>
                    </div>
                    <div class="record__body">
                      <a class="record__title" href={`/notes/${note.id}`}>
                        {note.data.title}
                      </a>
                      {note.data.summary && (
                        <p class="record__summary">{note.data.summary}</p>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            )}
            <p class="panel__note">
              Formal preprints and publications will appear here once they
              exist. Until then, the public record remains intentionally
              note-first.
            </p>
          </section>

          <section class="panel">
            <p class="panel__kicker">Record</p>
            <h2>Academic path</h2>
            {trajectory.length === 0 ? (
              <p class="empty-state">CV entries will appear here as they are added.</p>
            ) : (
              <ul class="record-list record-list--timeline" role="list">
                {trajectory.map((entry) => (
                  <li class="record">
                    <div class="record__badge">{formatRange(entry.data.start, entry.data.end)}</div>
                    <div class="record__body">
                      <span class="record__title">{entry.data.title}</span>
                      {(entry.data.organization || entry.data.location) && (
                        <p class="record__meta">
                          {entry.data.organization}
                          {entry.data.organization && entry.data.location && ' · '}
                          {entry.data.location}
                        </p>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </section>
        </div>

        <aside class="aside-stack">
          <section class="panel panel--muted">
            <p class="panel__kicker">Reading Programme</p>
            <h2>Current reading</h2>
            <ul class="compact-list">
              <li>Hartshorne, <em>Algebraic Geometry</em>, Chapters II–III.</li>
              <li>Eisenbud–Harris, <em>3264 and All That</em>.</li>
              <li>Vakil, <em>The Rising Sea</em>, as a parallel reference.</li>
            </ul>
          </section>

          <section class="panel panel--muted">
            <p class="panel__kicker">Keywords</p>
            <h2>Research areas</h2>
            <div class="tag-list" aria-label="Research topics">
              <span class="tag">algebraic geometry</span>
              <span class="tag">intersection theory</span>
              <span class="tag">cubic surfaces</span>
              <span class="tag">classical projective geometry</span>
              <span class="tag">expository writing</span>
            </div>
          </section>

          <section class="panel panel--muted">
            <p class="panel__kicker">Updates</p>
            <h2>Recent activity</h2>
            {recentUpdates.length === 0 ? (
              <p class="empty-state">No public updates yet.</p>
            ) : (
              <ul class="mini-list" role="list">
                {recentUpdates.map((note) => (
                  <li class="mini-list__item">
                    <time class="mini-list__date" datetime={note.data.date.toISOString()}>
                      {fmtNews.format(note.data.date)}
                    </time>
                    <a href={`/notes/${note.id}`}>{note.data.title}</a>
                  </li>
                ))}
              </ul>
            )}
          </section>

          <section class="panel panel--muted">
            <p class="panel__kicker">Teaching</p>
            <h2>Outreach and tutoring</h2>
            <p>
              I tutor <em>Oberstufe</em> mathematics through
              <a href="https://www.lern-fair.de" rel="external noopener">
                {' '}Lern-Fair
              </a>
              {' '}and run the
              <a href="https://youtube.com/@MaPhy-Club" rel="external noopener">
                {' '}MaPhy-Club
              </a>
              {' '}YouTube channel for mathematics and physics.
            </p>
          </section>
        </aside>
      </div>

      <SocialIcons />
    </article>
  </div>
</Base>
