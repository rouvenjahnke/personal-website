---
import { SITE } from '~/consts';
import SiteHeader from '~/components/SiteHeader.astro';
import SiteFooter from '~/components/SiteFooter.astro';
import CookieNotice from '~/components/CookieNotice.astro';

import '@fontsource-variable/eb-garamond/index.css';
import '@fontsource-variable/eb-garamond/wght-italic.css';
import '@fontsource-variable/inter/index.css';

import '~/styles/tokens.css';
import '~/styles/reset.css';
import '~/styles/base.css';
import '~/styles/layout.css';
import '~/styles/print.css';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  noindex?: boolean;
  /** When set, used as the og:type. Defaults to "website". */
  ogType?: 'website' | 'article';
  /** ISO date for article pages. */
  publishedTime?: string;
  /** Temporary chrome-less mode: hides primary nav and footer, keeps site title only. */
  minimal?: boolean;
}

const {
  title,
  description = SITE.description,
  canonicalPath,
  noindex = false,
  ogType = 'website',
  publishedTime,
  minimal = false,
} = Astro.props;

const fullTitle = title ? `${title} — ${SITE.name}` : SITE.title;

// Normalise the served URL: strip the build-time `.html` suffix and any
// `/index` segment so canonical/og:url match what Cloudflare Pages serves
// (and what the sitemap emits).
const rawPath = canonicalPath ?? Astro.url.pathname;
const cleanPath =
  rawPath
    .replace(/\.html$/i, '')
    .replace(/\/index$/i, '')
  || '/';
const canonical = new URL(cleanPath, SITE.url).toString();
const ogImage = new URL('/og-default.svg', SITE.url).toString();
// Strip `.html` from the runtime pathname too, so nav `aria-current="page"`
// matches "/research" rather than "/research.html".
const pathname = Astro.url.pathname.replace(/\.html$/i, '').replace(/\/index$/i, '') || '/';
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} — Notes`}
      href="/notes/rss.xml"
    />

    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={SITE.locale} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <slot name="head" />

    <script is:inline>
      // Hide the informational privacy notice synchronously for returning
      // visitors who dismissed it previously; must run before <body> to
      // avoid a flash of the banner on every page load.
      try {
        if (localStorage.getItem('site-notice-dismissed') === '1') {
          document.documentElement.classList.add('notice-dismissed');
        }
      } catch (_) { /* storage blocked; fall through to showing the notice */ }
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="site">
      <SiteHeader pathname={pathname} minimal={minimal} />
      <main id="main" class="site__main">
        <slot />
      </main>
      {!minimal && <SiteFooter />}
    </div>
    {!minimal && <CookieNotice />}
  </body>
</html>
