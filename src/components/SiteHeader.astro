---
import { SITE, NAV } from '~/consts';

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;

const isCurrent = (href: string): boolean => {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname === href || pathname.startsWith(href + '/');
};

// Format the brand the al-folio way: bold first name, regular last name.
const [first, ...rest] = SITE.name.split(' ');
const last = rest.join(' ');
---

<header class="site-header" role="banner">
  <nav class="navbar" aria-label="Primary">
    <div class="container navbar__inner">
      <a class="navbar__brand" href="/" rel="home">
        <span class="navbar__brand-name">
          <strong>{first}</strong>{last ? ' ' + last : ''}
        </span>
        <span class="navbar__brand-meta">mathematics · algebraic geometry</span>
      </a>
      <ul class="navbar__nav" role="list">
        {NAV.map((item) => (
          <li>
            <a
              class="navbar__link"
              href={item.href}
              aria-current={isCurrent(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <button
            type="button"
            class="navbar__toggle"
            id="theme-toggle"
            aria-label="Toggle colour theme"
            title="Toggle colour theme"
          >
            <span data-icon="moon" aria-hidden="true">☾</span>
            <span data-icon="sun"  aria-hidden="true">☀</span>
          </button>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script>
  // Persist theme choice. Initial paint already happened with the
  // no-flash inline script in Base.astro; this only handles clicks.
  const btn = document.getElementById('theme-toggle');
  const root = document.documentElement;
  btn?.addEventListener('click', () => {
    const current = root.getAttribute('data-theme');
    const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const effective = current ?? (systemDark ? 'dark' : 'light');
    const next = effective === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    try { localStorage.setItem('theme', next); } catch (_) {}
  });
</script>
